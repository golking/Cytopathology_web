APP_NAME=RSV Analysis Service
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

STORAGE_ROOT=
ENABLE_DEV_WORKER=true
DEV_WORKER_POLL_INTERVAL_SEC=0.5

